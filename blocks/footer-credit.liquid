
{% assign block_settings = block.settings %}
<div
  class="
    footer-utilities__group-credit
    custom-typography
    {% if block_settings.font_size != "" %}custom-font-size{% endif %}
  "
  style="
    {% render 'typography-style', preset: 'custom', settings: block_settings %}
    {% if block_settings.text_color != blank %}--color-utilities: {{ block_settings.text_color }};{% endif %}
  "
  {{ block.shopify_attributes }}
>
  <a
    href="{{ block_settings.link | default: 'https://castaar.be' }}"
    class="footer-utilities__text footer-credit"
    target="_blank"
    rel="noopener"
  >
    By
    <span class="footer-credit__logo svg-wrapper" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="72.418" height="10.61" viewBox="0 0 72.418 10.61">
