      </svg>
    </span>
  </a>
</div>

{% stylesheet %}
  .footer-utilities__group-credit {
    color: var(--color-utilities, var(--color-foreground-muted));
  }

  .footer-credit {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .footer-credit__logo {
    display: inline-flex;
    align-items: center;
    height: 0.7em;
    width: auto;
  }

  .footer-credit__logo svg {
    height: 100%;
    width: auto;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Credit",
  "tag": null,
  "settings": [
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.link",
      "info": "Defaults to https://castaar.be"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:settings.text_color",
      "placeholder": "t:settings.default"
    },
    {
      "type": "select",
      "id": "font_size",
      "label": "t:settings.size",
      "options": [
        {
          "value": "0.625rem",
          "label": "10px"
        },
        {
          "value": "0.75rem",
          "label": "12px"
        },
        {
          "value": "0.875rem",
          "label": "14px"
        },
        {
          "value": "1rem",
          "label": "16px"
        },
        {
          "value": "1.125rem",
          "label": "18px"
        }
      ],
      "default": "0.75rem"
    },
    {
      "type": "select",
      "id": "case",
      "label": "t:settings.case",
      "options": [
        {
          "value": "none",
          "label": "t:options.default"
        },
        {
          "value": "uppercase",
          "label": "t:options.uppercase"
        }
      ],
      "default": "none"
    }
  ],
  "presets": [
    {
      "name": "Credit",
      "category": "t:categories.footer"
    }
  ]
}
{% endschema %}
